# Copy to .env.local (gitignored) and paste real keys.

# Google AI Studio key — primary LLM for vision parse + text calls (aistudio.google.com)
VITE_GEMINI_API_KEY=

# Optional: Vultr Serverless Inference key for text calls (my.vultr.com)
VITE_VULTR_API_KEY=

# Gradium key — speech-to-text (gradium.ai)
VITE_GRADIUM_API_KEY=
